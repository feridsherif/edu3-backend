# Application Environment
NODE_ENV=development
PORT=3000

# CORS Configuration
# Use specific domain(s) for production, e.g., "https://yourdomain.com"
CORS_ORIGIN=*

# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgresql://edu3_user:secure_password@localhost:5432/edu3_db

# JWT Secrets (generate strong random strings in production)
# Example: openssl rand -base64 32
JWT_ACCESS_SECRET=a7f8e3d2b9c4f1e6a5d8c2b9e4f1a7d3c6b9e2f5a8d1c4e7b0f3a6d9c2e5f8
JWT_REFRESH_SECRET=f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f9e8d7c6b5a4f3e2d1c0b9a8

# JWT Token Expiration Times
# Format: "7d", "24h", "30m", etc. (see ms library format)
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Application Host/URL
# Used for generating links in emails (activation, invitations)
# Example: https://yourdomain.com or http://localhost:3000
HOST=http://localhost:3000

# SMTP Configuration (Email Service)
# For Gmail: use App Password (not regular password)
# For other providers: consult your email service documentation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
